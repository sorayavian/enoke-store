# ───────── Site ─────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Placeholder — trocar pelo número definitivo antes de produção
NEXT_PUBLIC_WHATSAPP_NUMBER=5511984333042

# ───────── Supabase ─────────
# Em dev local usar `supabase start` (CLI) e copiar daqui:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NUNCA exponha no client. Usar apenas em route handlers / server actions.
SUPABASE_SERVICE_ROLE_KEY=

# ───────── Mercado Pago ─────────
# Server only — checkout cria preference com este token
MERCADOPAGO_ACCESS_TOKEN=
# Pode ir para o client (SDK do MP)
NEXT_PUBLIC_MP_PUBLIC_KEY=
# Server only — usado para validar assinatura do webhook
MERCADOPAGO_WEBHOOK_SECRET=

# ───────── Painel administrativo ─────────
# true ativa a proteção do /admin (middleware). Em dev pode ficar vazio/false.
ADMIN_PROTECTION_ENABLED=true
# Senha de acesso ao painel (defina uma senha forte).
ADMIN_PASSWORD=
# Segredo para assinar o cookie de sessão do admin. Gere um valor aleatório:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_SESSION_SECRET=

# ───────── IA (Anthropic Claude) ─────────
# Quando preenchida, a IA passa a responder de verdade (modelo claude-sonnet-4-6).
# Sem a chave, o atendimento roda em modo demonstração (stub/heurística).
# Cada chamada real registra tokens e custo na tabela ai_logs.
# Pegue a chave em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Interruptor global da resposta automática: "false" desliga a IA (mensagens
# ainda chegam e são salvas, mas ninguém responde automático). Vazio/"true" liga.
AI_AUTO_REPLY_ENABLED=

# ───────── Mensagens (WhatsApp / Instagram) ─────────
# Evolution API (WhatsApp). A IA responde sozinha quando as 3 estão preenchidas.
WHATSAPP_API_URL=          # base da instância, ex.: https://evo.seudominio.com
WHATSAPP_API_TOKEN=        # apikey global da Evolution
WHATSAPP_INSTANCE=         # nome da instância conectada (o número que atende)
# Meta Graph API (Instagram DMs / publicação) — pronto, ative quando conectar a conta
META_GRAPH_TOKEN=
IG_VERIFY_TOKEN=           # token combinado no painel da Meta para validar o webhook
IG_BUSINESS_ID=            # (opcional) id da conta Instagram business

# ───────── Geração de conteúdo (Instagram) ─────────
OPENAI_API_KEY=          # DALL-E 3 (imagens)
RUNWAYML_API_KEY=        # vídeos/Reels (opcional)
